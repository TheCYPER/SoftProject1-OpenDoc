# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./collab_editor.db

# Auth
SECRET_KEY=change-me-in-production

# AI Provider (default: ollama for free local inference)
AI_DEFAULT_PROVIDER=ollama

# OpenAI (optional - user can also provide via request)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic / Claude (optional - user can also provide via request)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:8b
